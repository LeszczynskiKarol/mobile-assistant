generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Conversation {
  id        String   @id @default(cuid())
  topic     String?  // generowany przez Claude z pierwszego prompta
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Zagregowane statystyki (aktualizowane po każdej wiadomości)
  totalInputTokens  Int   @default(0)
  totalOutputTokens Int   @default(0)
  totalCostUsd      Float @default(0)
  messageCount      Int   @default(0)

  messages Message[]

  @@index([createdAt(sort: Desc)])
  @@index([topic])
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  role    String // 'user' | 'assistant'
  content String // treść wiadomości

  // Statystyki tokenów (tylko dla assistant, null dla user)
  inputTokens  Int?
  outputTokens Int?
  totalTokens  Int?
  costUsd      Float?
  model        String?
  latencyMs    Int?

  // Dane z Claude response (tylko assistant)
  actions    Json?   // wykonane akcje
  thinking   String? // co Claude "pomyślał"
  needsInput Boolean @default(false)

  createdAt DateTime @default(now())

  @@index([conversationId, createdAt])
  @@index([role])
}
